{
  "name": "@jango-blockchained/hoox-cli",
  "version": "0.6.1",
  "description": "Hoox CLI — manage Cloudflare Workers, infrastructure, secrets, and deployments (@jango-blockchained/hoox-cli)",
  "type": "module",
  "bin": {
    "hoox": "bin/hoox.js",
    "hx": "bin/hoox.js"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint .",
    "typecheck": "tsc --noEmit",
    "build": "bun build ./src/index.ts --outdir ./dist --target bun",
    "prepublishOnly": "bun run build && bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^1.3.0",
    "ansis": "^4.2.0",
    "commander": "^15.0.0",
    "jsonc-parser": "^3.3.1",
    "wrangler": "^4.97.0"
  },
  "devDependencies": {
    "@jango-blockchained/hoox-shared": "workspace:*",
    "@types/node": "^25.8.0",
    "bun-types": "^1.3.14",
    "typescript": "^6.0.3"
  },
  "publishConfig": {
    "access": "public"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jango-blockchained/hoox-setup.git"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "cli",
    "trading",
    "crypto",
    "automation",
    "hoox"
  ],
  "author": "Hoox Team",
  "license": "MIT",
  "engines": {
    "bun": ">=1.0"
  },
  "files": [
    "bin",
    "dist",
    "README.md"
  ]
}
