{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "esModuleInterop": true,
    "moduleResolution": "Bundler",
    "outDir": "./dist",
    "baseUrl": ".",
    "types": ["bun-types", "node", "@cloudflare/workers-types"],
    "paths": {
      "@jango-blockchained/hoox-shared": ["../shared/src/index.ts"]
    },
    "skipLibCheck": true
  },
  "include": ["src/**/*", "bin/**/*"],
  "exclude": ["tests/**/*", "node_modules", "dist"]
}
