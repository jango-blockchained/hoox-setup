{
  "name": "@hoox/cli",
  "version": "0.1.0",
  "description": "Official Hoox CLI for deploying and operating Cloudflare workers, pages, and secrets.",
  "type": "module",
  "main": "./bin/hoox.ts",
  "types": "./bin/hoox.ts",
  "exports": {
    ".": "./bin/hoox.ts"
  },
  "bin": {
    "hoox": "./bin/hoox.ts"
  },
  "scripts": {
    "test": "bun test",
    "test:coverage": "bun test --coverage",
    "lint": "eslint . --ext .ts",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "bun run lint && bun run typecheck"
  },
  "dependencies": {
    "@clack/prompts": "^0.8.2",
    "@hoox/shared": "workspace:*",
    "@opentui/core": "^0.2.0",
    "@opentui/react": "^0.2.0",
    "ansis": "^3.17.0",
    "react": "^19.2.5",
    "toml": "^3.0.0",
    "zod": "^4.4.3",
    "jsonc-parser": "^3.3.1"
  },
  "devDependencies": {
    "@types/node": "^20.17.31",
    "@types/react": "^19.2.14",
    "bun-types": "^1.3.13",
    "typescript": "^5.0.0"
  },
  "publishConfig": {
    "access": "public",
    "registry": "https://registry.npmjs.org"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/jango-blockchained/hoox-setup.git"
  },
  "keywords": [
    "cloudflare",
    "workers",
    "cli",
    "trading",
    "crypto",
    "automation",
    "hoox"
  ],
  "author": "Hoox Team",
  "license": "MIT",
  "engines": {
    "node": ">=18",
    "bun": ">=1.0"
  },
  "homepage": "https://github.com/jango-blockchained/hoox-setup/tree/main/packages/hoox-cli",
  "bugs": {
    "url": "https://github.com/jango-blockchained/hoox-setup/issues"
  },
  "files": [
    "bin",
    "src",
    "README.md"
  ]
}
