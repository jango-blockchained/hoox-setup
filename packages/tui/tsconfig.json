{
  "compilerOptions": {
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "bundler",
    "jsx": "react-jsx",
    "jsxImportSource": "@opentui/react",
    "types": ["bun", "react", "@cloudflare/workers-types"],
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "noEmit": true,
    "paths": {
      "@/*": ["./src/*"],
      "@hoox/shared": ["../shared/src"],
      "@hoox/shared/*": ["../shared/*"],
      "@jango-blockchained/hoox-shared": ["../shared/src/index.ts"],
      "@jango-blockchained/hoox-shared/*": ["../shared/src/*"],
      "@hoox/test-utils": ["../test-utils/src"],
      "@hoox/test-utils/*": ["../test-utils/src/*"]
    }
  },
  "include": ["src/**/*.ts", "src/**/*.tsx", "test/**/*.ts", "test/**/*.tsx"],
  "exclude": ["node_modules", "dist"]
}
