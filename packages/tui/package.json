{
  "name": "@jango-blockchained/hoox-tui",
  "version": "0.1.7",
  "description": "Hoox algorithmic trading terminal operations center — OpenTUI dashboard",
  "type": "module",
  "main": "src/main.tsx",
  "scripts": {
    "dev": "bun run src/main.tsx",
    "build": "bun build src/main.tsx --outdir dist --target bun",
    "start": "bun run src/main.tsx",
    "test": "bun test --preload ./src/test-setup.ts",
    "test:e2e": "bun test --preload ./src/test-setup.ts test/e2e/",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@opentui-ui/toast": "^0.0.5",
    "@opentui/core": "^0.2.12",
    "@opentui/react": "^0.2.12",
    "immer": "^11.1.8",
    "react": "^19.2.6",
    "smol-toml": "^1.6.1",
    "zustand": "^5.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260602.1",
    "@types/bun": "latest",
    "typescript": "^6.0.3"
  },
  "license": "MIT",
  "peerDependencies": {
    "@jango-blockchained/hoox-shared": "workspace:*"
  }
}
