{
  "name": "hoox",
  "version": "0.1.0",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers/*",
    "pages/*"
  ],
  "scripts": {
    "test:integration": "vitest run --config vitest.config.ts",
    "tests": "bun run ./packages/hoox-cli/src/run-tests.ts",
    "tests:watch": "bun run ./packages/hoox-cli/src/run-tests.ts --watch",
    "tests:coverage": "bun run ./packages/hoox-cli/src/run-tests.ts --coverage",
    "tui": "./hoox-tui",
    "dev": "./hoox-tui",
    "manage": "hoox",
    "init": "hoox init",
    "check-setup": "hoox check-setup",
    "housekeeping": "hoox housekeeping",
    "pages:deploy": "hoox pages deploy",
    "workers:clone": "hoox workers clone",
    "workers:setup": "hoox workers setup",
    "workers:deploy": "hoox workers deploy",
    "workers:status": "hoox workers status",
    "workers:dev": "hoox workers dev",
    "workers:test": "hoox workers test",
    "workers:update-urls": "hoox workers update-internal-urls",
    "keys:generate": "hoox keys generate",
    "keys:get": "hoox keys get",
    "keys:list": "hoox keys list",
    "secrets:check": "hoox secrets check",
    "secrets:update": "hoox secrets update-cf",
    "secrets:guide": "hoox secrets guide",
    "lint": "eslint . --ext .js,.ts",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write .",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "typecheck:prod": "tsc -p tsconfig.prod.json --noEmit",
    "generate-types": "tsc -p tsconfig.prod.json --declaration --emitDeclarationOnly --outDir types",
    "build-ignore-errors": "tsc -p tsconfig.prod.json --skipLibCheck --noEmit || echo 'Build completed with TypeScript warnings'",
    "migrate:tracking": "bun run ./scripts/migrate-tracking.sh",
    "docker:dev": "docker-compose up --build",
    "docker:dev:build": "docker build -f Dockerfile.dev . --tag hoox:dev",
    "docker:prod": "docker build -f Dockerfile.prod . --tag hoox:prod && docker run -p 8080:8080 hoox:prod",
    "docker:down": "docker-compose down",
    "lint:scripts": "bun run ./scripts/check-script-paths.ts",
    "check:worker-submodules": "bun run ./scripts/check-worker-submodules.ts"
  },
  "devDependencies": {
    "@cloudflare/ai": "^1.2.2",
    "@cloudflare/vitest-pool-workers": "^0.15.0",
    "@cloudflare/workers-types": "^4.20250430.0",
    "@hono/zod-validator": "^0.2.2",
    "@types/blessed": "^0.1.25",
    "@types/commander": "^2.12.5",
    "@types/node": "^20.17.31",
    "@typescript-eslint/eslint-plugin": "^7.0.0",
    "@typescript-eslint/parser": "^7.0.0",
    "bun-types": "^1.3.13",
    "eslint": "^8.0.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "next": "^16.2.4",
    "prettier": "^3.0.0",
    "shadcn": "^4.4.0",
    "tsx": "^4.19.3",
    "typescript": "^6.0.3",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "ethers": "^6.13.7",
    "hono": "^4.4.12",
    "zod": "^3.24.3"
  }
}
