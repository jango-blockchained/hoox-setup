{
  "name": "hoox",
  "version": "0.4.1",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers/*",
    "pages/*"
  ],
  "scripts": {
    "test": "bun test --path-ignore-patterns 'tests/live/**'",
    "test:live": "bun test tests/live/ --jobs 1",
    "test:cli": "bun test packages/cli/",
    "test:tui": "bun test packages/tui/",
    "test:shared": "bun test packages/shared/",
    "test:workers": "bun test workers/",
    "test:integration": "bun test tests/integration/",
    "test:e2e": "bun test tests/e2e/ tests/e2e.test.ts",
    "test:load": "k6 run tests/load/webhook-flow.js && k6 run tests/load/d1-query-load.js && k6 run tests/load/system-mixed.js && k6 run tests/load/agent-cron-sim.js",
    "test:all": "bun run lint && bun run typecheck && bun test && bun test:live",
    "build": "bun run build:packages && bun run typecheck",
    "build:packages": "bun run build:cli && bun run build:tui",
    "build:cli": "cd packages/cli && bun run build",
    "build:tui": "cd packages/tui && bun run build",
    "build:dashboard": "cd workers/dashboard && bun run build",
    "build:docs": "cd pages/docs && bun run build",
    "typecheck": "tsc --noEmit",
    "typecheck:prod": "tsc -p tsconfig.prod.json --noEmit",
    "generate-types": "tsc -p tsconfig.prod.json --declaration --emitDeclarationOnly --outDir types",
    "build-ignore-errors": "tsc -p tsconfig.prod.json --skipLibCheck --noEmit || echo 'Build completed with TypeScript warnings'",
    "tui": "./hoox-tui",
    "dev": "./hoox-tui",
    "manage": "hoox",
    "hoox": "hoox",
    "hx": "hoox",
    "lint": "eslint packages/ workers/*/src workers/*/test workers/dashboard/src --no-error-on-unmatched-pattern",
    "lint:fix": "eslint packages/ workers/*/src workers/*/test workers/dashboard/src --fix",
    "format": "prettier --write .",
    "migrate:tracking": "bun run ./scripts/migrate-tracking.sh",
    "docker:dev": "docker-compose up --build",
    "docker:dev:build": "docker build -f Dockerfile.dev . --tag hoox:dev",
    "docker:prod": "docker build -f Dockerfile.prod . --tag hoox:prod && docker run -p 8080:8080 hoox:prod",
    "docker:down": "docker-compose down",
    "prepare": "husky",
    "lint-staged": "lint-staged",
    "lint:scripts": "bun run ./scripts/check-script-paths.ts",
    "check:worker-submodules": "bun run ./scripts/check-worker-submodules.ts",
    "start": "node server.js"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260516.1",
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/commander": "^2.12.5",
    "@types/node": "^25.8.0",
    "@typescript-eslint/eslint-plugin": "^8.59.3",
    "@typescript-eslint/parser": "^8.59.3",
    "bun-types": "^1.3.14",
    "eslint": "^10.4.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.4",
    "prettier": "^3.8.3",
    "shadcn": "^4.7.0",
    "svgo": "^4.0.1"
  },
  "dependencies": {
    "@opentui-ui/dialog": "^0.1.2",
    "@tailwindcss/vite": "^4.3.0",
    "blessed": "^0.1.81",
    "react": "^19.2.6",
    "react-reconciler": "^0.33.0",
    "rolldown": "^1.0.1",
    "tailwindcss": "^4.3.0",
    "vite": "^8.0.14",
    "wrangler": "^4.93.1",
    "zod": "^4.4.3"
  },
  "description": "<div align=\"center\">",
  "main": "eslint.config.js",
  "directories": {
    "doc": "docs",
    "test": "tests"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/jango-blockchained/hoox-setup.git"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "bugs": {
    "url": "https://github.com/jango-blockchained/hoox-setup/issues"
  },
  "homepage": "https://github.com/jango-blockchained/hoox-setup#readme"
}
