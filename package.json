{
  "name": "hoox",
  "version": "0.3.4",
  "type": "module",
  "workspaces": [
    "packages/*",
    "workers/*",
    "pages/*"
  ],
  "scripts": {
    "test:integration": "vitest run --config vitest.config.ts",
    "test": "bun test",
    "test:cli": "bun test --cwd packages/cli",
    "test:live": "bun test tests/live/ --jobs 1",
    "test:all": "bun run lint && bun run typecheck && bun test && bun test:integration && bun test:live",
    "tui": "./hoox-tui",
    "dev": "./hoox-tui",
    "manage": "hoox",
    "hoox": "hoox",
    "lint": "eslint packages/ workers/*/src workers/*/test workers/dashboard/src --no-error-on-unmatched-pattern",
    "lint:fix": "eslint . --ext .js,.ts --fix",
    "format": "prettier --write .",
    "build": "tsc --noEmit",
    "typecheck": "tsc --noEmit",
    "typecheck:prod": "tsc -p tsconfig.prod.json --noEmit",
    "generate-types": "tsc -p tsconfig.prod.json --declaration --emitDeclarationOnly --outDir types",
    "build-ignore-errors": "tsc -p tsconfig.prod.json --skipLibCheck --noEmit || echo 'Build completed with TypeScript warnings'",
    "migrate:tracking": "bun run ./scripts/migrate-tracking.sh",
    "docker:dev": "docker-compose up --build",
    "docker:dev:build": "docker build -f Dockerfile.dev . --tag hoox:dev",
    "docker:prod": "docker build -f Dockerfile.prod . --tag hoox:prod && docker run -p 8080:8080 hoox:prod",
    "docker:down": "docker-compose down",
    "lint:scripts": "bun run ./scripts/check-script-paths.ts",
    "check:worker-submodules": "bun run ./scripts/check-worker-submodules.ts"
  },
  "devDependencies": {
    "@cloudflare/vitest-pool-workers": "^0.16.3",
    "@cloudflare/workers-types": "^4.20260506.1",
    "@eslint/js": "^10.0.1",
    "@types/blessed": "^0.1.27",
    "@types/commander": "^2.12.5",
    "@types/node": "^25.6.0",
    "@typescript-eslint/eslint-plugin": "^8.59.2",
    "@typescript-eslint/parser": "^8.59.2",
    "bun-types": "^1.3.13",
    "eslint": "^10.3.0",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.5.5",
    "globals": "^17.6.0",
    "prettier": "^3.8.3",
    "shadcn": "^4.7.0",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "blessed": "^0.1.81",
    "ethers": "^6.16.0",
    "zod": "^4.4.3"
  }
}
