{
  // Root wrangler.jsonc — deployment config for all workers
  //
  // NOTE: This file is gitignored (actual secrets and IDs should never
  // be committed). Copy to wrangler.jsonc and customize.
  //
  // Use `hoox setup` to automatically configure this file.

  "global": {
    "cloudflare_api_token": "<USE_CLOUDFLARE_API_TOKEN_ENV_OR_WRANGLER_AUTH>",
    "cloudflare_account_id": "<YOUR_ACCOUNT_ID>",
    "subdomain_prefix": "<YOUR_PREFIX>"
  },
  "workers": {
    "d1-worker": {
      "enabled": true,
      "path": "workers/d1-worker",
      "vars": {
        "database_name": "trade-data-db"
      },
      "secrets": []
    },
    "hoox": {
      "enabled": true,
      "path": "workers/hoox",
      "vars": {},
      "secrets": [
        "WEBHOOK_API_KEY_BINDING"
      ]
    },
    "agent-worker": {
      "enabled": true,
      "path": "workers/agent-worker",
      "vars": {},
      "secrets": [
        "AGENT_INTERNAL_KEY",
        "INTERNAL_KEY_BINDING"
      ]
    },
    "analytics-worker": {
      "enabled": true,
      "path": "workers/analytics-worker",
      "vars": {},
      "secrets": [
        "CLOUDFLARE_API_TOKEN"
      ]
    },
    "trade-worker": {
      "enabled": true,
      "path": "workers/trade-worker",
      "vars": {},
      "secrets": [
        "BINANCE_KEY_BINDING",
        "BINANCE_SECRET_BINDING",
        "BYBIT_KEY_BINDING",
        "BYBIT_SECRET_BINDING",
        "MEXC_KEY_BINDING",
        "MEXC_SECRET_BINDING"
      ]
    },
    "telegram-worker": {
      "enabled": true,
      "path": "workers/telegram-worker",
      "vars": {},
      "secrets": [
        "TG_BOT_TOKEN_BINDING"
      ]
    },
    "web3-wallet-worker": {
      "enabled": true,
      "path": "workers/web3-wallet-worker",
      "vars": {},
      "secrets": [
        "WALLET_MNEMONIC_SECRET",
        "WALLET_PK_SECRET"
      ]
    },
    "email-worker": {
      "enabled": true,
      "path": "workers/email-worker",
      "vars": {},
      "secrets": []
    },
    "report-worker": {
      "enabled": true,
      "path": "workers/report-worker",
      "vars": {},
      "secrets": []
    },
    "dashboard": {
      "enabled": true,
      "path": "workers/dashboard",
      "vars": {},
      "secrets": [
        "DASHBOARD_USER",
        "DASHBOARD_PASS",
        "SESSION_SECRET",
        "D1_INTERNAL_KEY",
        "AGENT_INTERNAL_KEY",
        "TRADE_INTERNAL_KEY",
        "TELEGRAM_INTERNAL_KEY",
        "API_SERVICE_KEY"
      ]
    }
  },
  "dev": {
    "runtime": "docker"
  }
}
