{
  "//": "Hoox Setup Configuration - Pages",
  "//": "This is the configuration file for Pages deployments (dashboard).",

  "global": {
    "//": "Cloudflare API Token (Required - same as workers.jsonc)",
    "cloudflare_api_token": "",

    "//": "Cloudflare Account ID (Required - same as workers.jsonc)",
    "cloudflare_account_id": "",

    "//": "A unique prefix for your worker subdomains",
    "subdomain_prefix": ""
  },

  "pages": {
    "dashboard": {
      "enabled": true,
      "path": "pages/dashboard",
      "project_name": "hoox-dashboard",
      "vars": {
        "D1_WORKER_URL": "https://d1-worker.<subdomain>.workers.dev",
        "AGENT_SERVICE_URL": "https://agent-worker.<subdomain>.workers.dev",
        "TRADE_SERVICE_URL": "https://trade-worker.<subdomain>.workers.dev",
        "TELEGRAM_SERVICE_URL": "https://telegram-worker.<subdomain>.workers.dev"
      },
      "secrets": ["DASHBOARD_USER", "DASHBOARD_PASS"]
    }
  }
}