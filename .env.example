# Hoox Main Global Configuration Example
# Run `hoox setup --yes` to automatically generate all required keys,
# create the D1 database, set Cloudflare secrets, and configure .dev.vars files.
#
# This file documents the configuration variables used by the setup system.
# Manual configuration is NOT recommended — use `hoox setup` instead.

# ------------------------------------------------------------------------------
# CLOUDFLARE ACCOUNT CONFIGURATION
# ------------------------------------------------------------------------------
# Your Cloudflare API Token (needs permissions for Workers, KV, D1, Queues, R2)
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"

# Your Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"

# Prefix used to deploy your workers (e.g., if prefix is "hoox", URLs will be
# worker-name.hoox.workers.dev)
SUBDOMAIN_PREFIX="hoox"

# ------------------------------------------------------------------------------
# GLOBAL SHARED SECRETS
# ------------------------------------------------------------------------------
# Internal authentication keys used for inter-worker communication.
# Generated automatically by `hoox setup`.
INTERNAL_KEY_BINDING="generate_a_secure_random_string_for_d1"
TRADE_INTERNAL_KEY="generate_a_secure_random_string_for_trade"
AGENT_INTERNAL_KEY="generate_a_secure_random_string_for_agent"

# Telegram Bot Token for notification worker
TG_BOT_TOKEN_BINDING="your_telegram_bot_token"

# API keys for the AI Agent Worker
AGENT_OPENAI_KEY="your_openai_api_key"
AGENT_ANTHROPIC_KEY="your_anthropic_api_key"
AGENT_GOOGLE_KEY="your_google_api_key"

# ------------------------------------------------------------------------------
# EXCHANGE CONFIGURATION
# ------------------------------------------------------------------------------
# Set your preferred API keys for exchange execution (trade-worker)
BINANCE_KEY_BINDING="your_binance_api_key"
BINANCE_SECRET_BINDING="your_binance_api_secret"

MEXC_KEY_BINDING="your_mexc_api_key"
MEXC_SECRET_BINDING="your_mexc_api_secret"

BYBIT_KEY_BINDING="your_bybit_api_key"
BYBIT_SECRET_BINDING="your_bybit_api_secret"

# ------------------------------------------------------------------------------
# DASHBOARD SPECIFIC
# ------------------------------------------------------------------------------
# The dashboard uses Next.js and has its own environment variables for session handling
DASHBOARD_USER="admin"
DASHBOARD_PASS="secure_password"
SESSION_SECRET="generate_a_32_character_secure_random_string"
