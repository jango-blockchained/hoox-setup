# Hoox Main Global Configuration Example
# Copy this file to .env.local to configure your local development environment

# ------------------------------------------------------------------------------
# CLOUDFLARE ACCOUNT CONFIGURATION
# ------------------------------------------------------------------------------
# Your Cloudflare API Token (needs permissions for Workers, KV, D1, Pages)
CLOUDFLARE_API_TOKEN="your_cloudflare_api_token"

# Your Cloudflare Account ID
CLOUDFLARE_ACCOUNT_ID="your_cloudflare_account_id"

# Your Cloudflare Secret Store ID (if you are using Secret Store for bindings)
CLOUDFLARE_SECRET_STORE_ID="your_secret_store_id"

# Prefix used to deploy your workers (e.g., if prefix is "myapp", URLs will be worker-name.myapp.workers.dev)
SUBDOMAIN_PREFIX="hoox"

# ------------------------------------------------------------------------------
# GLOBAL SHARED SECRETS
# ------------------------------------------------------------------------------
# Internal authentication keys used for inter-worker communication
D1_INTERNAL_KEY="generate_a_secure_random_string_for_d1"
TRADE_INTERNAL_KEY="generate_a_secure_random_string_for_trade"
AGENT_INTERNAL_KEY="generate_a_secure_random_string_for_agent"

# Telegram Bot Token for notification worker
TELEGRAM_BOT_TOKEN="your_telegram_bot_token"

# API keys for the AI Agent Worker
AGENT_OPENAI_KEY="your_openai_api_key"
AGENT_ANTHROPIC_KEY="your_anthropic_api_key"
AGENT_GOOGLE_KEY="your_google_api_key"

# ------------------------------------------------------------------------------
# EXCHANGE CONFIGURATION
# ------------------------------------------------------------------------------
# Set your preferred API keys for exchange execution (trade-worker)
BINANCE_API_KEY="your_binance_api_key"
BINANCE_API_SECRET="your_binance_api_secret"

MEXC_API_KEY="your_mexc_api_key"
MEXC_API_SECRET="your_mexc_api_secret"

BYBIT_API_KEY="your_bybit_api_key"
BYBIT_API_SECRET="your_bybit_api_secret"

# ------------------------------------------------------------------------------
# DASHBOARD SPECIFIC
# ------------------------------------------------------------------------------
# The dashboard uses Next.js and has its own environment variables for session handling
DASHBOARD_USER="admin"
DASHBOARD_PASS="secure_password"
SESSION_SECRET="generate_a_32_character_secure_random_string"
