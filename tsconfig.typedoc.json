{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "types": ["bun-types", "node", "@cloudflare/workers-types"],
    "strict": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false
  },
  "include": [
    "packages/shared/src/**/*",
    "packages/cli/src/**/*",
    "packages/tui/src/**/*"
  ]
}
