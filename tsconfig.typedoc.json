{
  "compilerOptions": {
    "target": "es2020",
    "module": "esnext",
    "lib": ["es2020", "WebWorker", "DOM"],
    "moduleResolution": "bundler",
    "types": ["bun-types", "node", "@cloudflare/workers-types"],
    "esModuleInterop": true,
    "strict": false,
    "skipLibCheck": true,
    "jsx": "react-jsx",
    "noEmit": true,
    "allowJs": true,
    "checkJs": false,
    "isolatedModules": true,
    "allowImportingTsExtensions": true,
    "ignoreDeprecations": "5.0"
  },
  "include": [
    "packages/shared/src/**/*",
    "packages/cli/src/**/*",
    "packages/tui/src/**/*"
  ]
}
