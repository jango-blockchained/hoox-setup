digraph Hoox {
  rankdir=LR;
  splines=polyline;
  compound=true;
  newrank=true;

  // Node defaults
  node [shape=box, style=rounded, fontname="monospace", fontsize=10];
  edge [fontname="monospace", fontsize=8, arrowsize=0.6];

  subgraph cluster_infrastructure {
    label="infrastructure";
    style=filled;
    fillcolor="#f5f5f5";
    color="#9e9e9e";
    fontcolor="#212121";
    fontsize=12;
    fontname="monospace";

    "infra:d1:trade-data-db" [label="trade-data-db (D1)", shape=box];
    "infra:r2:trade-reports" [label="trade-reports (R2)", shape=box];
    "infra:r2:hoox-system-logs" [label="hoox-system-logs (R2)", shape=box];
    "infra:r2:user-uploads" [label="user-uploads (R2)", shape=box];
    "infra:kv:CONFIG_KV" [label="CONFIG_KV", shape=box];
    "infra:kv:SESSIONS_KV" [label="SESSIONS_KV", shape=box];
    "infra:kv:NEXT_INC_CACHE_KV" [label="NEXT_INC_CACHE_KV", shape=box];
    "infra:queue:trade-execution" [label="trade-execution (Queue)", shape=box];
    "infra:do:IDEMPOTENCY_STORE" [label="IdempotencyStore (Durable Object)", shape=box];
    "infra:ai:WORKERS_AI" [label="Workers AI", shape=box];
    "infra:vectorize:my-rag-index" [label="my-rag-index (Vectorize)", shape=box];
    "infra:analytics:hoox-analytics" [label="hoox-analytics (Analytics Engine)", shape=box];
    "infra:browser:REPORT_RENDERER" [label="Browser Rendering", shape=box];
  }

  subgraph cluster_packages_cli {
    label="packages/cli";
    style=filled;
    fillcolor="#d4f5f5";
    color="#00B4B4";
    fontcolor="#004d4d";
    fontsize=12;
    fontname="monospace";

    "packages/cli:packages/cli/src/index.ts:main" [label="main (entry)", shape=box, penwidth=2, peripheries=2];
    "packages/cli:packages/cli/src/index.ts:program" [label="program (entry)", shape=box, penwidth=2, peripheries=2];
