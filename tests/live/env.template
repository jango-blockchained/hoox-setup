# Cloudflare Services Live Test Suite
# Copy this to .env and fill in your values.
# ALL values are required unless marked optional.
#
# USE A DEVELOPMENT/STAGING ACCOUNT — NOT PRODUCTION!

# Cloudflare API token with these permissions:
#   - Workers (Edit)
#   - D1 (Edit)
#   - KV (Edit)
#   - R2 (Edit)
#   - Queues (Edit)
#   - AI (Read)
#   - Account (Read)
#   - Zone (Read)
CLOUDFLARE_API_TOKEN=

# Cloudflare Account ID (from dashboard > Overview)
CLOUDFLARE_ACCOUNT_ID=

# Zone ID for DNS/WAF tests (optional — some tests will skip)
CLOUDFLARE_ZONE_ID=

# D1 database name (must already exist)
HOOX_D1_DATABASE=my-database

# KV namespace ID (optional — tested via `wrangler kv namespace list`)
HOOX_KV_NAMESPACE_ID=

# R2 bucket name for test objects (optional — created/destroyed by tests)
HOOX_R2_BUCKET=hoox-live-test

# Queue name for test messaging (optional — created/destroyed by tests)
HOOX_QUEUE=hoox-live-test-queue

# Worker name for Durable Object tests (optional — must exist with DO binding)
HOOX_DO_WORKER=hoox
