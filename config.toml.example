[global]
# Cloudflare API Token (Recommended over API Key/Email for better security)
# Obtain from: Cloudflare Dashboard > My Profile > API Tokens > Create Token > Use "Edit Cloudflare Workers" template
cloudflare_api_token = "" # PASTE YOUR TOKEN HERE or leave empty to be prompted

# Cloudflare Account ID
# Obtain from: Cloudflare Dashboard > Select your domain > Overview page (bottom right)
cloudflare_account_id = "" # PASTE YOUR ACCOUNT ID HERE or leave empty to be prompted

# Cloudflare Secret Store ID (Required for Secret Store bindings)
# Obtain from: Cloudflare Dashboard > Secrets Store or `wrangler secrets-store store list`
cloudflare_secret_store_id = "" # PASTE YOUR STORE ID HERE or leave empty to be prompted

# A unique prefix for your worker subdomains (e.g., "my-app")
# Final URLs will look like: worker-name.prefix.workers.dev
subdomain_prefix = "" # CHOOSE A PREFIX or leave empty to be prompted

# Optional: Specify the path to your global .env file if you use one for secrets NOT managed by wrangler
# dotenv_path = ".env"

[secrets]
# Define names for secrets that might be shared or referenced across workers
# The actual values should be set via wrangler secret put (handled by the script) or manually in the dashboard
# Example:
# TELEGRAM_BOT_TOKEN = "" # Leave value empty, script will prompt or use environment variable if needed

[workers.d1-worker]
enabled = true # Set to true to enable this worker during setup/deployment
# Path relative to the project root
path = "workers/d1-worker"
# Worker-specific environment variables for wrangler.toml or .dev.vars
vars = { database_name = "my-database" }
# Secrets needed by this worker (names defined in Cloudflare secrets)
# The script will try to set these using wrangler secret put
secrets = [] # Example: ["DATABASE_URL_SECRET"]

[workers.telegram-worker]
enabled = true
path = "workers/telegram-worker"
vars = {}
secrets = ["TELEGRAM_BOT_TOKEN"] # Assumes a secret named TELEGRAM_BOT_TOKEN exists in Cloudflare

[workers.trade-worker]
enabled = true
path = "workers/trade-worker"
vars = {}
secrets = ["API_SERVICE_KEY"] # Example

[workers.web3-wallet-worker]
enabled = true
path = "workers/web3-wallet-worker"
vars = {}
# The mnemonic needs to be stored securely. The script should prompt for it.
secrets = ["MNEMONIC"]

[workers.hoox]
enabled = true
path = "workers/hoox"
description = "Central webhook processing and dynamic routing worker"

[workers.home-assistant]
enabled = true
path = "workers/home-assistant-worker"
vars = {}
secrets = ["HA_TOKEN","HA_SECURE_URL"] # Token for Home Assistant API authentication

[workers.agent-worker]
enabled = false
path = "workers/agent-worker"
vars = {}
secrets = []

[workers.email-worker]
enabled = true
path = "workers/email-worker"
vars = { USE_IMAP = "false" }
# USE_IMAP=true - Scan inbox via IMAP (set secrets: EMAIL_HOST, EMAIL_USER, EMAIL_PASS)
# USE_IMAP=false - Use email webhooks (default)
# 
# Supported webhooks:
# - Mailgun: POST application/x-www-form-urlencoded
# - SendGrid: POST application/json
# - Gmail: POST from Google Workspace/gmail-api notifications
# - Direct: POST JSON with signal data
#
# Email body formats supported:
# - JSON: {"exchange":"binance","action":"buy","symbol":"BTCUSDT","quantity":100}
# - Plaintext: keyword-based extraction (exchange, action, symbol, quantity, price, leverage)
secrets = ["EMAIL_HOST", "EMAIL_USER", "EMAIL_PASS", "INTERNAL_KEY"]

[pages.dashboard]
enabled = true
path = "pages/dashboard"
secrets = []
