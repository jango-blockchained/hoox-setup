# Dashboard Configuration (used at build time by Next.js)
#
# IMPORTANT: For the production deployment, these values come from Cloudflare
# secrets (wrangler secret put) and the wrangler.jsonc vars section.
# This file is for local development reference only.
#
# Use `hoox setup` to generate and deploy all required secrets.

# Auth Type: "basic" | "cf-access" | "none"
AUTH_TYPE=basic

# Basic Auth Credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=your-secure-password

# Session secret for cookie signing
SESSION_SECRET=change-this-to-a-random-string

# Internal service keys
AGENT_INTERNAL_KEY=your-agent-internal-key
D1_INTERNAL_KEY=your-d1-internal-key
TRADE_INTERNAL_KEY=your-trade-internal-key
TELEGRAM_INTERNAL_KEY=your-telegram-internal-key

# Worker URLs (set via wrangler.jsonc vars in production)
D1_WORKER_URL=https://d1-worker.your-subdomain.workers.dev
TRADE_WORKER_URL=https://trade-worker.your-subdomain.workers.dev
AGENT_WORKER_URL=https://agent-worker.your-subdomain.workers.dev
TELEGRAM_WORKER_URL=https://telegram-worker.your-subdomain.workers.dev
