{
  "name": "hoox-dashboard",
  "pages_build_output_dir": ".vercel/output/static",
  "compatibility_date": "2025-03-07",
  "compatibility_flags": ["nodejs_compat"],
  "kv_namespaces": [
    {
      "binding": "CONFIG_KV",
      "id": "your-config-kv-id-here"
    }
  ],
  "vars": {
    "D1_WORKER_URL": "https://d1-worker.your-subdomain.workers.dev",
    "AGENT_SERVICE_URL": "https://agent-worker.your-subdomain.workers.dev",
    "TRADE_SERVICE_URL": "https://trade-worker.your-subdomain.workers.dev",
    "TELEGRAM_SERVICE_URL": "https://telegram-worker.your-subdomain.workers.dev"
  }
}
