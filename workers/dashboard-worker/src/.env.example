# Dashboard Configuration

# Auth Type: "basic" | "cf-access" | "none"
AUTH_TYPE=basic
SESSION_SECRET=change-this-to-a-random-string

# Basic Auth Credentials
DASHBOARD_USER=admin
DASHBOARD_PASS=your-secure-password

# Cloudflare Access (if AUTH_TYPE=cf-access)
CF_ACCESS_TEAM_NAME=your-team-name

# API Endpoints (optional - will use defaults if not set)
D1_SERVICE_URL=https://d1-worker.your-subdomain.workers.dev
TRADE_SERVICE_URL=https://trade-worker.your-subdomain.workers.dev
AGENT_SERVICE_URL=https://agent-worker.your-subdomain.workers.dev
TELEGRAM_SERVICE_URL=https://telegram-worker.your-subdomain.workers.dev

# Internal Keys (must match worker secrets)
D1_INTERNAL_KEY=your-d1-internal-key
TRADE_INTERNAL_KEY=your-trade-internal-key
AGENT_INTERNAL_KEY=your-agent-internal-key