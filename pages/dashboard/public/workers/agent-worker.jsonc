{
  "display_name": "Agent Worker",
  "description": "AI risk manager and autonomous agent",
  "sections": {
    "cron": {
      "title": "Schedule",
      "description": "Cron and automation settings",
      "icon": "clock",
      "priority": 20,
      "fields": {
        "enabled": true,
        "interval_minutes": 5,
        "housekeeping_enabled": true
      }
    },
    "behavior": {
      "title": "Behavior",
      "description": "Autonomous behavior settings",
      "icon": "activity",
      "priority": 30,
      "fields": {
        "auto_trailing_stop": true,
        "auto_rebalance": false,
        "risk_override_enabled": true
      }
    },
    "agent": {
      "title": "AI Configuration",
      "description": "Configure the AI Agent's execution parameters and secret keys.",
      "icon": "brain",
      "priority": 10,
      "fields": {
        "config": "{ \"enabled\": true, \"risk_mode\": \"conservative\" }",
        "openai_key": "Requires CLI Setup",
        "anthropic_key": "Requires CLI Setup",
        "google_key": "Requires CLI Setup"
      },
      "descriptions": {
        "config": "JSON configuration string governing the agent's behavior and risk management algorithms.",
        "openai_key": "OpenAI API Key (Secret). DO NOT save this plaintext via Dashboard. Manually execute: 'bun run scripts/manage.ts secrets update-cf openai_key agent-worker' in your terminal.",
        "anthropic_key": "Anthropic API Key (Secret). DO NOT save this plaintext via Dashboard. Manually execute: 'bun run scripts/manage.ts secrets update-cf anthropic_key agent-worker' in your terminal.",
        "google_key": "Google Gemini API Key (Secret). DO NOT save this plaintext via Dashboard. Manually execute: 'bun run scripts/manage.ts secrets update-cf google_key agent-worker' in your terminal."
      }
    }
  }
}