{
  "name": "docs-site",
  "version": "0.1.0",
  "description": "Hoox documentation site built with Astro",
  "license": "CC-BY-4.0",
  "type": "module",
  "private": true,
  "scripts": {
    "dev": "astro dev",
    "build": "PUPPETEER_EXECUTABLE_PATH=${PUPPETEER_EXECUTABLE_PATH:-$(which chromium 2>/dev/null || echo '')} bun run scripts/build-docs-extras.ts && astro build",
    "preview": "astro preview",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@astrojs/react": "5.0.6",
    "@base-ui/react": "^1.4.1",
    "@fontsource-variable/ibm-plex-sans": "^5.2.8",
    "@fontsource/ibm-plex-mono": "^5.2.7",
    "@fontsource/bebas-neue": "^5.2.7",
    "@jango-blockchained/hoox-shared": "workspace:*",
    "astro": "6.4.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "lucide-react": "^1.16.0",
    "mermaid": "^11.15.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "shadcn": "^4.7.0",
    "tailwind-merge": "^3.6.0",
    "tw-animate-css": "^1.4.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "4.3.0",
    "@types/markdown-it": "^14.1.2",
    "@types/node": "^25.9.0",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "markdown-it": "^14.2.0",
    "markdown-it-attrs": "^5.0.0",
    "markdown-it-footnote": "^4.0.0",
    "markdown-it-task-lists": "^2.1.1",
    "puppeteer": "^25.1.0",
    "shiki": "^4.1.0",
    "tailwindcss": "4.3.0",
    "typescript": "^6.0.3",
    "vite": "8.0.14"
  },
  "author": "jango-blockchained"
}
