{
  "extends": "../../tsconfig.json",
  "compilerOptions": {
    "jsx": "preserve",
    "strict": true,

    "paths": {
      "@/*": ["./src/*"],
      "@jango-blockchained/hoox-shared": ["../../packages/shared/src/index.ts"],
      "@jango-blockchained/hoox-shared/*": ["../../packages/shared/src/*"]
