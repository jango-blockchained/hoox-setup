---
import DocLayout from "@/layouts/DocLayout.astro";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const docs = await getCollection("docs");
  return docs.map((doc) => ({
    params: { slug: doc.id.replace(/\.md$/, "") },
    props: { doc },
  }));
}

const { doc } = Astro.props;
const { Content, headings } = await render(doc);

const title = doc.data.title || doc.id.split("/").pop()?.replace(/\.md$/, "") || "Untitled";
const description = doc.data.description;
const slug = doc.id.replace(/\.md$/, "");
---

<DocLayout title={title} description={description} currentSlug={slug} headings={headings}>
  <Content />
</DocLayout>
