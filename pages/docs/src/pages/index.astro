---
import DocLayout from "@/layouts/DocLayout.astro";
import { getCollection, render } from "astro:content";

const allDocs = await getCollection("docs");
const homeDoc = allDocs.find((d) => d.id === "home.md" || d.id === "index.md");
let Content: any = null;
const headings: Array<{ depth: number; text: string; slug: string }> = [];

if (homeDoc) {
  const result = await render(homeDoc);
  Content = result.Content;
}
---

<DocLayout title="Home" currentSlug="home" headings={headings}>
  {Content ? <Content /> : <h1>Welcome to Hoox Docs</h1>}
</DocLayout>
