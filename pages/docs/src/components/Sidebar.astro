---
import type { NavSection } from "@/lib/navigation";
import { cn } from "@/lib/utils";

export interface Props {
  sections: NavSection[];
  currentSlug?: string;
}
const { sections, currentSlug } = Astro.props;

const sectionSvgIcons: Record<string, string> = {
  rocket:
    '<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4.5 16.5c-1.5 1.26-2 5-2 5s3.74-.5 5-2c.71-.84.7-2.13-.09-2.91a2.18 2.18 0 0 0-2.91-.09z"/><path d="M12 15l-3-3a22 22 0 0 1 2-3.95A12.88 12.88 0 0 1 22 2c0 2.72-.78 7.5-6 11a22.35 22.35 0 0 1-4 2z"/><path d="M9 12H4s.55-3.03 2-4c1.62-1.08 5 0 5 0"/><path d="M12 15v5s3.03-.55 4-2c1.08-1.62 0-5 0-5"/></svg>',
  book:
    '<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M4 19.5A2.5 2.5 0 0 1 6.5 17H20"/><path d="M6.5 2H20v20H6.5A2.5 2.5 0 0 1 4 19.5v-15A2.5 2.5 0 0 1 6.5 2z"/></svg>',
  "book-open":
    '<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M2 3h6a4 4 0 0 1 4 4v14a3 3 0 0 0-3-3H2z"/><path d="M22 3h-6a4 4 0 0 0-4 4v14a3 3 0 0 1 3-3h7z"/></svg>',
  lightbulb:
    '<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M9 18h6"/><path d="M10 22h4"/><path d="M15.09 14c.18-.98.65-1.74 1.41-2.5A4.65 4.65 0 0 0 18 8 6 6 0 0 0 6 8c0 1 .23 2.23 1.5 3.5A4.61 4.61 0 0 1 8.91 14"/></svg>',
  target:
    '<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"/><circle cx="12" cy="12" r="6"/><circle cx="12" cy="12" r="2"/></svg>',
  gear:
    '<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="3"/><path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42"/></svg>',
};
---

<aside
  class="hidden md:block w-64 shrink-0 border-r border-border bg-background h-[calc(100vh-3.5rem)] sticky top-14"
>
  <!-- Sidebar uses native browser scrolling with custom-scrollbar utility -->
  <nav class="flex h-full flex-col gap-1 overflow-y-auto p-4 custom-scrollbar">
    <!-- Audience Toggle -->
    <div class="flex rounded-lg border border-border p-0.5 mb-2 bg-muted/50 shrink-0" role="tablist" aria-label="Documentation audience">
      <button
        class="audience-toggle flex-1 rounded-md px-3 py-1.5 text-xs font-medium transition-all data-active:bg-background data-active:text-foreground data-active:shadow-sm text-muted-foreground hover:text-foreground"
        data-audience="user"
        onclick="switchAudience('user')"
      >
        End User
      </button>
      <button
        class="audience-toggle flex-1 rounded-md px-3 py-1.5 text-xs font-medium transition-all data-active:bg-background data-active:text-foreground data-active:shadow-sm text-muted-foreground hover:text-foreground"
        data-audience="devops"
        onclick="switchAudience('devops')"
      >
        DevOps
      </button>
    </div>

    <!-- Home link -->
    <a
      href="/hoox-setup/"
      class={cn(
        "flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium transition-colors shrink-0 font-mono",
        (!currentSlug || currentSlug === "home")
          ? "bg-muted text-foreground"
          : "text-muted-foreground hover:bg-muted/70 hover:text-foreground"
      )}
    >
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 9l9-7 9 7v11a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2z" />
        <polyline points="9 22 9 12 15 12 15 22" />
      </svg>
      <span>Home</span>
    </a>

    <!-- Divider -->
    <div class="my-1 h-px bg-border shrink-0" role="separator"></div>

    <!-- Navigation sections -->
    {
      sections.map((section) => (
        <div class="mt-1 audience-section" data-audience={section.audience}>
          <div class="flex items-center gap-2 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-accent font-mono">
            <span class="text-accent/70" set:html={sectionSvgIcons[section.icon] || sectionSvgIcons.book} />
            <span>{section.title}</span>
          </div>
          <div class="ml-1 flex flex-col mt-0.5 sidebar-nav-list">
            {section.items.map((item, idx) => (
              <div class="sidebar-nav-item relative flex">
                <!-- Connector line -->
                <div class="sidebar-connector flex flex-col items-center shrink-0" aria-hidden="true">
                  <span class="sidebar-connector-dot mt-[13px] size-1.5 rounded-full border border-muted-foreground/30 bg-transparent"></span>
                  {idx < section.items.length - 1 && (
                    <span class="sidebar-connector-line w-px flex-1 bg-border/60"></span>
                  )}
                </div>
                <a
                  href={`/hoox-setup/${item.slug}/`}
                  class={cn(
                    "flex items-start gap-2 rounded-md px-3 py-1.5 text-sm leading-snug transition-colors font-mono flex-1 min-w-0",
                    currentSlug === item.slug
                      ? "bg-muted text-foreground font-medium"
                      : "text-muted-foreground hover:bg-muted/70 hover:text-foreground"
                  )}
                >
                  <span class="[word-break:break-word] hyphens-auto">{item.title}</span>
                </a>
              </div>
            ))}
          </div>
        </div>
      ))
    }
  </nav>
</aside>
