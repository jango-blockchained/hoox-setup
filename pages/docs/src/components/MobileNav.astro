---
import type { NavSection } from "@/lib/navigation";
import { cn } from "@/lib/utils";

export interface Props {
  sections: NavSection[];
  currentSlug?: string;
}
const { sections, currentSlug } = Astro.props;
---

<div
  id="mobile-nav"
  class="hidden fixed inset-0 z-50 md:hidden"
  role="dialog"
  aria-label="Navigation"
>
  <!-- Backdrop -->
  <div
    class="fixed inset-0 bg-black/50"
    onclick="document.getElementById('mobile-nav').classList.add('hidden')"
  ></div>

  <!-- Panel -->
  <div class="fixed left-0 top-0 bottom-0 w-72 bg-background border-r border-border overflow-y-auto z-10 shadow-2xl">
    <div class="flex items-center justify-between p-4 border-b border-border">
      <span class="font-semibold">Navigation</span>
      <button
        onclick="document.getElementById('mobile-nav').classList.add('hidden')"
        class="inline-flex items-center justify-center rounded-md h-8 w-8 hover:bg-accent"
        aria-label="Close"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <path d="M18 6L6 18M6 6l12 12" />
        </svg>
      </button>
    </div>

    <nav class="p-4 flex flex-col gap-1">
      <!-- Audience Toggle -->
      <div class="flex rounded-lg border border-border p-0.5 mb-2 bg-muted/50" role="tablist" aria-label="Documentation audience">
        <button
          class="mobile-audience-toggle flex-1 rounded-md px-3 py-1.5 text-xs font-medium transition-all data-active:bg-background data-active:text-foreground data-active:shadow-sm text-muted-foreground hover:text-foreground"
          data-audience="user"
          onclick="switchAudience('user')"
        >
          End User
        </button>
        <button
          class="mobile-audience-toggle flex-1 rounded-md px-3 py-1.5 text-xs font-medium transition-all data-active:bg-background data-active:text-foreground data-active:shadow-sm text-muted-foreground hover:text-foreground"
          data-audience="devops"
          onclick="switchAudience('devops')"
        >
          DevOps
        </button>
      </div>

      <a
        href="/hoox-setup/"
        onclick="document.getElementById('mobile-nav').classList.add('hidden')"
        class={cn(
          "flex items-center gap-2 rounded-md px-3 py-2 text-sm font-medium",
          (!currentSlug || currentSlug === "home")
            ? "bg-accent text-accent-foreground"
            : "text-muted-foreground hover:bg-muted"
        )}
      >
        <span>📄</span>
        <span>Home</span>
      </a>

      {
        sections.map((section) => (
          <div class="mt-2 mobile-audience-section" data-audience={section.audience}>
            <div class="flex items-center gap-2 px-3 py-1.5 text-xs font-semibold uppercase tracking-wider text-muted-foreground">
              <span>{section.icon}</span>
              <span>{section.title}</span>
            </div>
            <div class="ml-1 flex flex-col gap-0.5 mt-1">
              {section.items.map((item) => (
                <a
                  href={`/hoox-setup/${item.slug}/`}
                  onclick="document.getElementById('mobile-nav').classList.add('hidden')"
                  class={cn(
                    "flex items-center gap-2 rounded-md px-3 py-1.5 text-sm",
                    currentSlug === item.slug
                      ? "bg-accent text-accent-foreground font-medium"
                      : "text-muted-foreground hover:bg-muted"
                  )}
                >
                  <span class="truncate">{item.title}</span>
                </a>
              ))}
            </div>
          </div>
        ))
      }
    </nav>
  </div>
</div>

<script>
  // Mobile nav uses the same switchAudience function, but targets mobile elements
  var originalSwitch = window.switchAudience;

  window.switchAudience = function (audience) {
    // Update desktop toggle buttons
    document.querySelectorAll(".audience-toggle").forEach(function (btn) {
      var isActive = btn.getAttribute("data-audience") === audience;
      btn.toggleAttribute("data-active", isActive);
    });

    // Update mobile toggle buttons
    document.querySelectorAll(".mobile-audience-toggle").forEach(function (btn) {
      var isActive = btn.getAttribute("data-audience") === audience;
      btn.toggleAttribute("data-active", isActive);
    });

    // Show/hide desktop sections
    document.querySelectorAll(".audience-section").forEach(function (section) {
      var sectionAudience = section.getAttribute("data-audience");
      if (sectionAudience === audience) {
        section.classList.remove("hidden");
      } else {
        section.classList.add("hidden");
      }
    });

    // Show/hide mobile sections
    document.querySelectorAll(".mobile-audience-section").forEach(function (section) {
      var sectionAudience = section.getAttribute("data-audience");
      if (sectionAudience === audience) {
        section.classList.remove("hidden");
      } else {
        section.classList.add("hidden");
      }
    });

    // Store preference
    try {
      localStorage.setItem("docs-audience", audience);
    } catch (e) {}
  };

  // Init: default to user
  document.addEventListener("DOMContentLoaded", function () {
    // Activate "user" button by default on both
    document.querySelectorAll(".audience-toggle, .mobile-audience-toggle").forEach(function (btn) {
      if (btn.getAttribute("data-audience") === "user") {
        btn.toggleAttribute("data-active", true);
      }
    });

    // Hide devops sections initially
    document.querySelectorAll(".audience-section, .mobile-audience-section").forEach(function (section) {
      if (section.getAttribute("data-audience") !== "user") {
        section.classList.add("hidden");
      }
    });

    // Restore saved preference
    try {
      var saved = localStorage.getItem("docs-audience");
      if (saved === "user" || saved === "devops") {
        window.switchAudience(saved);
      }
    } catch (e) {}
  });
</script>
