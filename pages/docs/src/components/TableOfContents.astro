---
export interface Props {
  headings: Array<{ depth: number; text: string; slug: string }>;
}
const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth >= 2 && h.depth <= 3);
---

{
  filtered.length > 0 && (
    <!--
      Full-width layout: ToC is a fixed-width column on the right.
      Sticks below the header and scrolls independently.
    -->
    <aside class="hidden xl:block w-60 2xl:w-64 shrink-0 border-l border-border">
      <div class="sticky top-14 h-[calc(100vh-3.5rem)] overflow-y-auto py-8 pr-4 pl-4 custom-scrollbar">
        <p class="text-xs font-semibold uppercase tracking-wider text-muted-foreground mb-4 flex items-center gap-2">
          <svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
            <path d="M4 6h16M4 12h16M4 18h16" />
          </svg>
          On this page
        </p>
        <nav class="flex flex-col gap-1">
          {filtered.map((h) => (
            <a
              href={`#${h.slug}`}
              class={`block text-sm transition-colors hover:text-foreground border-l-2 py-1 pl-3 ${
                h.depth === 3
                  ? "ml-3 border-transparent text-muted-foreground/70 hover:border-muted-foreground/30"
                  : "border-transparent text-muted-foreground hover:border-foreground/30"
              }`}
            >
              {h.text}
            </a>
          ))}
        </nav>
      </div>
    </aside>
  )
}
