---
// No props needed — search state managed client-side via SearchDialog
---

<header class="sticky top-0 z-50 w-full border-b border-border bg-sidebar/95 backdrop-blur supports-[backdrop-filter]:bg-sidebar/80">
  <div class="flex h-14 items-center gap-4 px-4 lg:px-6">
    <!-- Mobile hamburger -->
    <button
      class="md:hidden inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground h-9 w-9"
      onclick="document.getElementById('mobile-nav').classList.toggle('hidden')"
      aria-label="Toggle navigation"
    >
      <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M3 12h18M3 6h18M3 18h18" />
      </svg>
    </button>

    <a href="/" class="flex items-center gap-2 font-semibold shrink-0">
      <svg class="size-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M12 2L2 7l10 5 10-5-10-5z" />
        <path d="M2 17l10 5 10-5" />
        <path d="M2 12l10 5 10-5" />
      </svg>
      Hoox Docs
    </a>

    <div class="hidden md:flex flex-1 max-w-sm ml-4">
      <button
        class="inline-flex items-center justify-center rounded-md border border-input bg-background px-3 py-2 text-sm text-muted-foreground w-full hover:bg-accent hover:text-accent-foreground transition-colors"
        onclick="window.__openSearch?.()"
      >
        <svg class="size-4 mr-2 shrink-0" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
          <circle cx="11" cy="11" r="8" />
          <path d="m21 21-4.35-4.35" />
        </svg>
        <span class="truncate">Search docs...</span>
        <kbd class="ml-auto pointer-events-none inline-flex h-5 select-none items-center gap-1 rounded border bg-muted px-1.5 font-mono text-[10px] font-medium text-muted-foreground shrink-0">
          ⌘K
        </kbd>
      </button>
    </div>

    <div class="flex items-center gap-2 ml-auto">
      <!-- Download offline docs -->
      <a
        href="/Enduser-Full-Documentation.pdf"
        download
        class="hidden lg:inline-flex items-center justify-center rounded-md text-xs font-mono ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground h-9 px-3 border border-border shrink-0"
        title="Download Enduser Full PDF"
      >
        USER.PDF
      </a>
      <a
        href="/DevOps-Full-Documentation.pdf"
        download
        class="hidden lg:inline-flex items-center justify-center rounded-md text-xs font-mono ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground h-9 px-3 border border-border shrink-0"
        title="Download DevOps Full PDF"
      >
        DEVOPS.PDF
      </a>
      <a
        href="/llm.txt"
        target="_blank"
        class="hidden lg:inline-flex items-center justify-center rounded-md text-xs font-mono ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground h-9 px-3 border border-border shrink-0"
        title="View Consolidated LLM Context Text"
      >
        LLM.TXT
      </a>

      <!-- Theme toggle -->
      <button
        id="theme-toggle"
        class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground h-9 w-9"
        aria-label="Toggle theme"
      >
        <svg class="size-4 dark:hidden" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <path d="M21 12.79A9 9 0 1 1 11.21 3 7 7 0 0 0 21 12.79z" />
        </svg>
        <svg class="size-4 hidden dark:block" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" aria-hidden="true">
          <circle cx="12" cy="12" r="5" />
          <path d="M12 1v2M12 21v2M4.22 4.22l1.42 1.42M18.36 18.36l1.42 1.42M1 12h2M21 12h2M4.22 19.78l1.42-1.42M18.36 5.64l1.42-1.42" />
        </svg>
      </button>

      <a
        href="https://github.com/jango-blockchained/hoox-setup"
        target="_blank"
        rel="noopener noreferrer"
        class="inline-flex items-center justify-center rounded-md text-sm font-medium ring-offset-background transition-colors hover:bg-accent hover:text-accent-foreground h-9 w-9"
        aria-label="GitHub repository"
      >
        <svg class="size-4" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
          <path d="M12 0c-6.626 0-12 5.373-12 12 0 5.302 3.438 9.8 8.207 11.387.599.111.793-.261.793-.577v-2.234c-3.338.726-4.033-1.416-4.033-1.416-.546-1.387-1.333-1.756-1.333-1.756-1.089-.745.083-.729.083-.729 1.205.084 1.839 1.237 1.839 1.237 1.07 1.834 2.807 1.304 3.492.997.107-.775.418-1.305.762-1.604-2.665-.305-5.467-1.334-5.467-5.931 0-1.311.469-2.381 1.236-3.221-.124-.303-.535-1.524.117-3.176 0 0 1.008-.322 3.301 1.23.957-.266 1.983-.399 3.003-.404 1.02.005 2.047.138 3.006.404 2.291-1.552 3.297-1.23 3.297-1.23.653 1.653.242 2.874.118 3.176.77.84 1.235 1.911 1.235 3.221 0 4.609-2.807 5.624-5.479 5.921.43.372.823 1.102.823 2.222v3.293c0 .319.192.694.801.576 4.765-1.589 8.199-6.086 8.199-11.386 0-6.627-5.373-12-12-12z"/>
        </svg>
      </a>
    </div>
  </div>
</header>

<script>
  // Theme toggle logic
  const toggle = document.getElementById("theme-toggle");
  if (toggle) {
    toggle.addEventListener("click", () => {
      const html = document.documentElement;
      const isDark = html.classList.contains("dark");
      html.classList.toggle("dark", !isDark);
      localStorage.setItem("theme", isDark ? "light" : "dark");
    });

    // Restore saved theme
    const saved = localStorage.getItem("theme");
    if (saved === "light") {
      document.documentElement.classList.remove("dark");
    }
  }
</script>
