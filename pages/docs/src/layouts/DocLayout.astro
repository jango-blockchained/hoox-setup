---
import "@/styles/globals.css";
import Header from "@/components/Header.astro";
import MobileNav from "@/components/MobileNav.astro";
import Sidebar from "@/components/Sidebar.astro";
import Footer from "@/components/Footer.astro";
import TableOfContents from "@/components/TableOfContents.astro";
import SearchDialog from "@/components/SearchDialog.tsx";
import { buildNavigation, getBreadcrumbs, getPrevNext, getHeaderMenus, filterNavigation } from "@/lib/navigation";
import { getCollection } from "astro:content";

export interface Props {
  title?: string;
  description?: string;
  currentSlug?: string;
  headings?: Array<{ depth: number; text: string; slug: string }>;
}

const { title, description, currentSlug, headings = [] } = Astro.props;
const allDocs = await getCollection("docs");
const allSections = buildNavigation(
  allDocs.map((doc: { id: string; data: { title?: string } }) => ({
    id: doc.id,
    title: doc.data.title,
  }))
);

// Compute navigation data for both audiences
const userSections = filterNavigation(allSections, "user");
const devopsSections = filterNavigation(allSections, "devops");
const breadcrumbs = getBreadcrumbs(currentSlug || "", allSections);
const { prev: userPrev, next: userNext } = getPrevNext(currentSlug || "", userSections);
const { prev: devopsPrev, next: devopsNext } = getPrevNext(currentSlug || "", devopsSections);
const headerMenus = getHeaderMenus(allSections);
const editUrl = currentSlug && currentSlug !== "home"
  ? `https://github.com/jango-blockchained/hoox-setup/edit/main/pages/docs/content/docs/${currentSlug}.md`
  : null;
---

<!doctype html>
<html lang="en" class="dark">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>{title ? `${title} — Hoox Docs` : "Hoox Docs"}</title>
    {description && <meta name="description" content={description} />}
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />
  </head>
  <body class="min-h-screen bg-background font-sans antialiased">
    <div class="relative z-10">
      <Header menus={headerMenus} />
      <MobileNav sections={allSections} currentSlug={currentSlug} />

      <div class="flex">
        <Sidebar sections={allSections} currentSlug={currentSlug} />

        <main class="flex-1 min-w-0">
          <div class="flex">
            <article class="flex-1 min-w-0 px-6 py-8 lg:px-12 xl:px-16 2xl:px-20">
              <!-- Breadcrumbs -->
              {
                breadcrumbs.length > 0 && (
                  <nav class="flex items-center gap-1.5 text-sm text-muted-foreground mb-6" aria-label="Breadcrumb">
                    {breadcrumbs.map((crumb, i) => (
                      <>
                        {i > 0 && (
                          <svg class="size-3.5 text-muted-foreground/50" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m9 18 6-6-6-6" />
                          </svg>
                        )}
                        {crumb.slug ? (
                          <a href={`/${crumb.slug}`} class="hover:text-foreground transition-colors">{crumb.title}</a>
                        ) : (
                          <span class="text-foreground/60">{crumb.title}</span>
                        )}
                      </>
                    ))}
                  </nav>
                )
              }

              <!-- Page title + description -->
              {title && (
                <div class="mb-8">
                  <h1 class="text-3xl font-bold tracking-tight text-foreground">{title}</h1>
                  {description && (
                    <p class="mt-2 text-lg text-muted-foreground">{description}</p>
                  )}
                </div>
              )}

              <!-- Content -->
              <div class="prose">
                <slot />
              </div>

              <!-- Edit this page -->
              {editUrl && (
                <div class="mt-12 pt-6 border-t border-border">
                  <a
                    href={editUrl}
                    target="_blank"
                    rel="noopener noreferrer"
                    class="inline-flex items-center gap-2 text-sm text-muted-foreground hover:text-foreground transition-colors"
                  >
                    <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                      <path d="M17 3a2.85 2.83 0 1 1 4 4L7.5 20.5 2 22l1.5-5.5Z"/>
                    </svg>
                    Edit this page on GitHub
                  </a>
                </div>
              )}

              <!-- Prev / Next navigation (dual-audience) -->
              {(userPrev || userNext || devopsPrev || devopsNext) && (
                <>
                  {/* User audience prev/next */}
                  <div class="mt-8 grid grid-cols-2 gap-4 audience-prevnext" data-audience="user">
                    {userPrev ? (
                      <a
                        href={`/${userPrev.slug}/`}
                        class="flex flex-col gap-1 rounded-lg border border-border p-4 hover:bg-accent/5 transition-colors group"
                      >
                        <span class="text-xs text-muted-foreground flex items-center gap-1">
                          <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m15 18-6-6 6-6" />
                          </svg>
                          Previous
                        </span>
                        <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">{userPrev.title}</span>
                      </a>
                    ) : <div />}
                    {userNext ? (
                      <a
                        href={`/${userNext.slug}/`}
                        class="flex flex-col gap-1 rounded-lg border border-border p-4 hover:bg-accent/5 transition-colors group text-right"
                      >
                        <span class="text-xs text-muted-foreground flex items-center gap-1 justify-end">
                          Next
                          <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                            <path d="m9 18 6-6-6-6" />
                          </svg>
                        </span>
                        <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">{userNext.title}</span>
                      </a>
                    ) : <div />}
                  </div>
                  {/* DevOps audience prev/next */}
                  {(devopsPrev || devopsNext) && (
                    <div class="mt-8 grid grid-cols-2 gap-4 audience-prevnext hidden" data-audience="devops">
                      {devopsPrev ? (
                        <a
                          href={`/${devopsPrev.slug}/`}
                          class="flex flex-col gap-1 rounded-lg border border-border p-4 hover:bg-accent/5 transition-colors group"
                        >
                          <span class="text-xs text-muted-foreground flex items-center gap-1">
                            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <path d="m15 18-6-6 6-6" />
                            </svg>
                            Previous
                          </span>
                          <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">{devopsPrev.title}</span>
                        </a>
                      ) : <div />}
                      {devopsNext ? (
                        <a
                          href={`/${devopsNext.slug}/`}
                          class="flex flex-col gap-1 rounded-lg border border-border p-4 hover:bg-accent/5 transition-colors group text-right"
                        >
                          <span class="text-xs text-muted-foreground flex items-center gap-1 justify-end">
                            Next
                            <svg class="size-3" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                              <path d="m9 18 6-6-6-6" />
                            </svg>
                          </span>
                          <span class="text-sm font-medium text-foreground group-hover:text-accent transition-colors">{devopsNext.title}</span>
                        </a>
                      ) : <div />}
                    </div>
                  )}
                </>
              )}
            </article>

            <TableOfContents headings={headings} />
          </div>
        </main>
      </div>

      <Footer />
      <SearchDialog client:only="react" />
    </div>

    <!-- Back-to-top button -->
    <button
      id="back-to-top"
      class="fixed bottom-6 right-6 z-40 flex size-9 items-center justify-center rounded-full border border-border bg-background/80 text-muted-foreground shadow-sm opacity-0 transition-all hover:bg-accent hover:text-foreground backdrop-blur supports-backdrop-filter:bg-background/60"
      aria-label="Scroll to top"
      onclick="window.scrollTo({ top: 0, behavior: 'smooth' })"
    >
      <svg class="size-4" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
        <path d="M18 15l-6-6-6 6" />
      </svg>
    </button>

    <script>
      // ── Mermaid diagram rendering ──
      async function initMermaid() {
        const pres = document.querySelectorAll('article.prose pre[data-language="mermaid"]');
        if (!pres.length) return;

        const { default: mermaid } = await import("mermaid");
        mermaid.initialize({
          startOnLoad: false,
          theme: "dark",
          themeVariables: {
            primaryColor: "#CCCCCC",
            primaryTextColor: "#e2e8f0",
            primaryBorderColor: "#334155",
            lineColor: "#64748b",
            secondaryColor: "#0f172a",
            tertiaryColor: "#CCCCCC",
            fontSize: "14px",
          },
        });

        for (const pre of pres) {
          const code = pre.querySelector("code")?.textContent || "";
          const wrapper = document.createElement("div");
          wrapper.className = "mermaid-wrapper";
          const id = "mermaid-" + Math.random().toString(36).slice(2, 9);
          const svg = document.createElement("div");
          svg.id = id;
          svg.className = "mermaid";
          svg.textContent = code;
          wrapper.appendChild(svg);
          pre.replaceWith(wrapper);
        }

        try {
          await mermaid.run({ querySelector: ".mermaid" });

          // ── Interactive Zoom & Pan for Mermaid SVGs ──
          document.querySelectorAll(".mermaid-wrapper").forEach((wrapper) => {
            const svgNode = wrapper.querySelector("svg");
            if (!svgNode) return;

            svgNode.style.transition = "transform 0.05s ease-out";
            svgNode.style.transformOrigin = "center center";

            let scale = 1;
            let translateX = 0;
            let translateY = 0;
            let isDragging = false;
            let startX = 0;
            let startY = 0;

            const updateTransform = () => {
              svgNode.style.transform = `translate(${translateX}px, ${translateY}px) scale(${scale})`;
            };

            wrapper.addEventListener("mousedown", (e) => {
              isDragging = true;
              wrapper.style.cursor = "grabbing";
              startX = e.clientX - translateX;
              startY = e.clientY - translateY;
              e.preventDefault();
            });

            window.addEventListener("mousemove", (e) => {
              if (!isDragging) return;
              translateX = e.clientX - startX;
              translateY = e.clientY - startY;
              updateTransform();
            });

            window.addEventListener("mouseup", () => {
              if (!isDragging) return;
              isDragging = false;
              wrapper.style.cursor = "grab";
            });

            wrapper.addEventListener("wheel", (e) => {
              e.preventDefault();
              const zoomFactor = 1.1;
              if (e.deltaY < 0) scale *= zoomFactor;
              else scale /= zoomFactor;
              scale = Math.max(0.3, Math.min(scale, 4.0));
              updateTransform();
            });

            wrapper.addEventListener("dblclick", () => {
              scale = 1;
              translateX = 0;
              translateY = 0;
              updateTransform();
            });
          });
        } catch (e) {
          console.warn("Mermaid render error:", e);
        }
      }

      // ── Code copy buttons ──
      function initCopyButtons() {
        document.querySelectorAll("article.prose pre").forEach((pre) => {
          if (pre.getAttribute("data-language") === "mermaid") return;

          const wrapper = document.createElement("div");
          wrapper.className = "code-block-wrapper";
          pre.parentNode?.insertBefore(wrapper, pre);
          wrapper.appendChild(pre);

          const btn = document.createElement("button");
          btn.className = "copy-button";
          btn.setAttribute("aria-label", "Copy code");
          btn.innerHTML = `<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
          btn.addEventListener("click", async () => {
            const code = pre.querySelector("code")?.textContent || "";
            await navigator.clipboard.writeText(code);
            btn.innerHTML = `<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M20 6L9 17l-5-5"/></svg>`;
            setTimeout(() => {
              btn.innerHTML = `<svg class="size-3.5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><rect x="9" y="9" width="13" height="13" rx="2" ry="2"/><path d="M5 15H4a2 2 0 0 1-2-2V4a2 2 0 0 1 2-2h9a2 2 0 0 1 2 2v1"/></svg>`;
            }, 2000);
          });
          wrapper.appendChild(btn);
        });
      }

      document.addEventListener("DOMContentLoaded", () => {
        initMermaid();
        initCopyButtons();
      });

      // ── Back-to-top visibility ──
      const btn = document.getElementById("back-to-top");
      if (btn) {
        let ticking = false;
        window.addEventListener("scroll", () => {
          if (!ticking) {
            requestAnimationFrame(() => {
              btn.style.opacity = window.scrollY > 400 ? "1" : "0";
              btn.style.pointerEvents = window.scrollY > 400 ? "auto" : "none";
              ticking = false;
            });
            ticking = true;
          }
        });
      }

      // ── Unified audience toggle (shared by Sidebar + MobileNav) ──
      window.switchAudience = function (audience) {
        document.querySelectorAll(".audience-toggle, .mobile-audience-toggle").forEach(function (btn) {
          const isActive = btn.getAttribute("data-audience") === audience;
          btn.toggleAttribute("data-active", isActive);
        });

        document.querySelectorAll(".audience-section").forEach(function (section) {
          section.style.display = section.getAttribute("data-audience") === audience ? "" : "none";
        });

        document.querySelectorAll(".mobile-audience-section").forEach(function (section) {
          section.classList.toggle("hidden", section.getAttribute("data-audience") !== audience);
        });

        document.querySelectorAll(".audience-prevnext").forEach(function (el) {
          el.classList.toggle("hidden", el.getAttribute("data-audience") !== audience);
        });

        try {
          localStorage.setItem("docs-audience", audience);
        } catch (e) {}
      };

      document.addEventListener("DOMContentLoaded", function () {
        const saved = localStorage.getItem("docs-audience") || "user";
        if (saved === "user" || saved === "devops") {
          window.switchAudience(saved);
        }
      });
    </script>
  </body>
</html>
