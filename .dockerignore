# Dependencies and build outputs
node_modules
.next
**/.next
**/.next/**
.git
**/.git
**/.git/**
.wrangler
**/.wrangler
dist
build
**/dist
**/dist/**
.bun

# Local secrets (defense in depth, also gitignored)
.env.local
.env.*.local
