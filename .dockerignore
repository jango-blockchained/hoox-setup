.dockerignore

# AI agent / IDE artifacts — not needed in build context
.opencode
.claude
.vscode
.idea

# Per-worker / per-package node_modules (belt-and-braces with `node_modules`)
**/node_modules
packages/*/node_modules
workers/*/node_modules

