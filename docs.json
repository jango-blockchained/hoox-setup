{
  "$schema": "https://mintlify.com/docs.json",
  "theme": "mint",
  "name": "Hoox",
  "description": "Zero-Latency Algorithmic Trading Ecosystem on the Cloudflare Edge. Free, open-source framework for trade signal ingestion, risk management, and execution at the edge.",
  "colors": {
    "primary": "#0D9373",
    "light": "#55D799",
    "dark": "#0D9373"
  },
  "favicon": "/favicon.svg",
  "logo": {
    "light": "/logo/light.svg",
    "dark": "/logo/dark.svg",
    "href": "https://github.com/jango-blockchained/hoox-setup"
  },
  "appearance": {
    "default": "system"
  },
  "fonts": {
    "family": "Inter"
  },
  "seo": {
    "indexing": "navigable",
    "metatags": {
      "og:site_name": "Hoox Documentation",
      "og:title": "Hoox — Zero-Latency Algorithmic Trading on the Cloudflare Edge",
      "og:description": "Free, open-source algorithmic trading framework deployed natively to the Cloudflare Edge Network. Trade signals, risk management, and execution in milliseconds.",
      "og:type": "website",
      "og:locale": "en_US",
      "og:image": "/og-image.png",
      "twitter:card": "summary_large_image",
      "twitter:site": "@hoox",
      "twitter:title": "Hoox Documentation",
      "twitter:description": "Zero-Latency Algorithmic Trading Ecosystem on the Cloudflare Edge.",
      "twitter:image": "/og-image.png",
      "canonical": "https://docs.hoox.sh",
      "robots": "index, follow"
    }
  },
  "search": {
    "prompt": "Search the Hoox docs..."
  },
  "metadata": {
    "timestamp": true
  },
  "banner": {
    "type": "info",
    "content": "Hoox is open-source software for algorithmic trading on the Cloudflare edge. Trading carries risk — test on staging first.",
    "dismissible": true
  },
  "navbar": {
    "links": [
      {
        "type": "github",
        "href": "https://github.com/jango-blockchained/hoox-setup"
      },
      {
        "label": "Support",
        "href": "mailto:support@hoox.sh"
      }
    ],
    "primary": {
      "type": "button",
      "label": "GitHub",
      "url": "https://github.com/jango-blockchained/hoox-setup"
    }
  },
  "footerSocials": {
    "github": "https://github.com/jango-blockchained/hoox-setup"
  },
  "footer": {
    "links": [
      {
        "header": "Resources",
        "items": [
          {
            "label": "Installation",
            "href": "/docs/enduser/getting-started/installation"
          },
          {
            "label": "Quick Start",
            "href": "/docs/enduser/getting-started/quick-start"
          },
          {
            "label": "CLI Reference",
            "href": "/docs/enduser/reference/cli-commands"
          },
          {
            "label": "API Endpoints",
            "href": "/docs/enduser/reference/api-endpoints"
          }
        ]
      },
      {
        "header": "Architecture",
        "items": [
          {
            "label": "DevOps Manual",
            "href": "/docs/devops"
          },
          {
            "label": "System Overview",
            "href": "/docs/devops/architecture/overview"
          },
          {
            "label": "Data Flow",
            "href": "/docs/devops/architecture/data-flow"
          },
          {
            "label": "Production Deployment",
            "href": "/docs/devops/deployment/production"
          }
        ]
      },
      {
        "header": "Community",
        "items": [
          {
            "label": "GitHub Repository",
            "href": "https://github.com/jango-blockchained/hoox-setup"
          },
          {
            "label": "Support",
            "href": "mailto:support@hoox.sh"
          },
          {
            "label": "Telegram Bot",
            "href": "/docs/enduser/tutorials/telegram-bot"
          }
        ]
      }
    ]
  },
  "api": {
    "openapi": "docs/openapi.yaml",
    "playground": {
      "display": "interactive"
    },
    "examples": {
      "languages": ["curl", "javascript", "python"],
      "defaults": "required",
      "prefill": true
    },
    "params": {
      "expanded": "all"
    }
  },
